    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "FirstName",
            "LastName",
            "PinCode"
        ],
        "properties": {
            "FirstName": {
                "type": "string"
            },
            "LastName": {
                "type": "string"
            },
            "PinCode": {
                "type": "integer"
            }
        }
    }
}